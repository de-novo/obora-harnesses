{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "Minimal viable todo app with web frontend and RESTful API",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev": "npm-run-all --parallel dev:api dev:web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
